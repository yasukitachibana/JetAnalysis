          <Item>4.0</Item>
          <Item>6.0</Item>
          <Item>8.0</Item>
          <Item>10.0</Item>
        </ktG>


      </var>
    </SoftDropGroom>

  </observable>


  <inputFiles>
    <inputStyle>JetScapeAsciiV2OneLine</inputStyle>
    <sigmaLastLine>1</sigmaLastLine>
    <events>
      <head>JetscapeHadronListBin</head>
      <join>_</join>
